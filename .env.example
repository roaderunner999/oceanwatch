# OceanWatch — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

ANTHROPIC_API_KEY=your-api-key-here

NODE_ENV=production
PORT=3000

# Comma-separated list of allowed CORS origins.
# Leave blank to allow all (fine for a public API).
# Example: ALLOWED_ORIGINS=https://oceanwatch.app,https://www.oceanwatch.app
ALLOWED_ORIGINS=https://oceanwatch.app,https://www.oceanwatch.app

# Optional: set a Bearer token that clients must send to hit /api routes.
# Leave blank for open access.
# CLIENT_SECRET=

# Detection thresholds (seconds)
SUBMERSION_WARNING_SECONDS=5
SUBMERSION_DANGER_SECONDS=10

# Per-IP daily scan cap
DAILY_SCAN_LIMIT=500
